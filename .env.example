# Configurações do Azure DevOps
# NUNCA comite arquivos .env com segredos reais no controle de versão.

# Nome da sua organização no Azure DevOps (Ex: minha-empresa)
VITE_AZURE_ORG=sua-organizacao

# Nome do projeto dentro da organização (Ex: meu-projeto)
VITE_AZURE_PROJECT=seu-projeto

# Personal Access Token (PAT)
# AVISO: Em produção, o ideal é usar uma Edge Function (Supabase) ou Proxy para não expor o PAT no Frontend.
VITE_AZURE_PAT=seu-token-aqui

# Endpoint da API (Se desejar usar um proxy intermediário no futuro)
VITE_AZURE_API_URL=https://dev.azure.com
